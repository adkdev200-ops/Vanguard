        "args": ["-y", "@playwright/mcp@latest"]
    },
    "filesystem": {
        "transport": "stdio",
        "command": "npx",
        "args": [
            "-y",
            "@modelcontextprotocol/server-filesystem",
            "/home/legion/Documents/BitsBot/outputs"
        ]
